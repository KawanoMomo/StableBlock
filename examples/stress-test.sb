block lb_main "Load Balancer\n(HAProxy)" at 24,12 size 12x5 color=#3B82F6 text=#FFFFFF round=4
block api_gw "API Gateway\n(Kong)" at 37,12 size 12x5 color=#3B82F6 text=#FFFFFF round=4
block graphql_gw "GraphQL\nGateway" at 50,12 size 10x5 color=#3B82F6 text=#FFFFFF round=4
block grpc_gw "gRPC\nGateway" at 61,12 size 10x5 color=#3B82F6 text=#FFFFFF round=4
block ws_gw "WebSocket\nGateway" at 72,12 size 10x5 color=#3B82F6 text=#FFFFFF round=4
