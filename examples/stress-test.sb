# ═══════════════════════════════════════
# Connections: Client → Gateway
# ═══════════════════════════════════════
web_app -> cdn
mobile_ios -> lb_main
mobile_android -> lb_main
desktop -> api_gw
cli_tool -> api_gw
admin_panel -> api_gw
partner_portal -> api_gw
iot_device -> grpc_gw
chatbot -> ws_gw
sdk_js -> api_gw
sdk_py -> api_gw
cdn -> waf
waf -> lb_main
lb_main -> api_gw
lb_main -> graphql_gw
lb_main -> grpc_gw
lb_main -> ws_gw

# Gateway → Auth
api_gw -> auth_svc
api_gw -> rate_limit
api_gw -> api_version
graphql_gw -> auth_svc
grpc_gw -> auth_svc
ws_gw -> session
ssl_term -> lb_main

# Auth internal
