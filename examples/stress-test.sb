# StableBlock v0.6 — Stress Test (Large Enterprise System)
# 150+ blocks, 30+ groups, 200+ connections
@canvas width=2400 height=2400 grid=20

# ═══════════════════════════════════════
# Layer 1: Client Applications
# ═══════════════════════════════════════
group clients "Client Applications" at 1,1 size 118x8 color=#EEF2FF border=#818CF8

block web_app "Web App\n(React)" at 2,3 size 10x5 color=#6366F1 text=#FFFFFF round=6
block mobile_ios "iOS App\n(Swift)" at 13,3 size 10x5 color=#6366F1 text=#FFFFFF round=6
block mobile_android "Android\n(Kotlin)" at 24,3 size 10x5 color=#6366F1 text=#FFFFFF round=6
block desktop "Desktop\n(Electron)" at 35,3 size 10x5 color=#6366F1 text=#FFFFFF round=6
block cli_tool "CLI Tool\n(Go)" at 46,3 size 10x5 color=#6366F1 text=#FFFFFF round=6
block admin_panel "Admin\nPanel" at 57,3 size 10x5 color=#6366F1 text=#FFFFFF round=6
block partner_portal "Partner\nPortal" at 68,3 size 10x5 color=#6366F1 text=#FFFFFF round=6
block iot_device "IoT\nDevices" at 79,3 size 10x5 color=#6366F1 text=#FFFFFF round=6
block chatbot "Chatbot\n(Slack)" at 90,3 size 10x5 color=#6366F1 text=#FFFFFF round=6
block sdk_js "JS SDK" at 101,3 size 8x5 color=#818CF8 text=#FFFFFF round=4
block sdk_py "Python SDK" at 110,3 size 8x5 color=#818CF8 text=#FFFFFF round=4

